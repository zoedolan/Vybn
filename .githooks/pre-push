#!/usr/bin/env bash
# Keep worthwhile work on the primary branch unless Zoe explicitly requests a branch.
set -euo pipefail

while read -r local_ref local_sha remote_ref remote_sha; do
  branch="${remote_ref#refs/heads/}"
  if [[ "$remote_ref" == refs/heads/* && "$branch" != main && "$branch" != master && "$branch" != gh-pages && "${VYBN_ALLOW_TOPIC_BRANCH:-0}" != 1 ]]; then
    cat >&2 <<EOF
[pre-push] refused work branch: $remote_ref

Commit and push tested work on the primary branch.
Zoe-requested exception: VYBN_ALLOW_TOPIC_BRANCH=1 git push
EOF
    exit 1
  fi
done
