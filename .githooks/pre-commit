#!/usr/bin/env bash
# Vybn pre-commit hook: security, membrane, shrinkage, sudo-n, subtraction.
# Install once per clone: git config core.hooksPath .githooks

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m'

BLOCKED=0

STAGED=$(git diff --cached --name-only --diff-filter=d 2>/dev/null || true)
if [ -z "$STAGED" ]; then
    exit 0
fi

# --- 1. High-entropy secrets ---
SECRETS_PATTERN='(sk-ant-api[A-Za-z0-9_-]{20,}|ghp_[A-Za-z0-9]{36,}|ghu_[A-Za-z0-9]{36,}|ghs_[A-Za-z0-9]{36,}|AKIA[A-Z0-9]{16}|-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY|request_zoe_contact|contact_affordance|call Zoe|phone number)'

for f in $STAGED; do
    [ "$f" = ".githooks/pre-commit" ] && continue
    git diff --cached -- "$f" | grep -qPi "$SECRETS_PATTERN" || continue
    echo -e "${RED}BLOCKED${NC}: Possible secret detected in ${f}"
    BLOCKED=1
done

# --- 2. Internal/Tailscale IPs ---
IP_PATTERN='\b(192\.168\.[0-9]{1,3}\.[0-9]{1,3}|10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}|100\.(6[4-9]|[7-9][0-9]|1[0-2][0-7])\.[0-9]{1,3}\.[0-9]{1,3})\b'

for f in $STAGED; do
    case "$f" in *.png|*.jpg|*.gif|*.ico|*.woff*|*.ttf) continue ;; esac
    matches=$(git diff --cached -- "$f" | grep -P "^\+" | grep -Po "$IP_PATTERN" | sort -u || true)
    if [ -n "$matches" ]; then
        echo -e "${YELLOW}WARNING${NC}: Possible internal IP in ${f}:"
        echo "$matches" | sed 's/^/  /'
        BLOCKED=1
    fi
done

# --- 3. Env files ---
for f in $STAGED; do
    case "$f" in
        *.env|.env.*|*/.env)
            echo -e "${RED}BLOCKED${NC}: Environment file staged: ${f}"
            BLOCKED=1
            ;;
    esac
done

# --- 4. Catastrophic shrinkage guard ---
# Override: VYBN_ALLOW_SHRINK=1 git commit
SHRINK_THRESHOLD=80   # percent

if [[ "${VYBN_ALLOW_SHRINK:-}" != "1" ]]; then
    for f in $STAGED; do
        if ! git cat-file -e "HEAD:${f}" 2>/dev/null; then
            continue
        fi
        case "$f" in *.png|*.jpg|*.gif|*.ico|*.woff*|*.ttf|*.pyc|*.bin) continue ;; esac

        prior_size=$(git cat-file -p "HEAD:${f}" | wc -c)
        staged_size=$(git show ":${f}" | wc -c)

        if [ "$prior_size" -gt 0 ]; then
                reduction=$(( (prior_size - staged_size) * 100 / prior_size ))
            if [ "$reduction" -ge "$SHRINK_THRESHOLD" ]; then
                echo -e "${RED}BLOCKED${NC}: ${f} shrank ${reduction}% (${prior_size} → ${staged_size} bytes)."
                echo "  This looks like an accidental overwrite."
                echo "  If intentional: VYBN_ALLOW_SHRINK=1 git commit"
                BLOCKED=1
            fi
        fi
    done
fi

# --- 5. sudo -n lint for shell scripts ---
# Override: VYBN_ALLOW_SUDO_HANG=1 git commit
if [[ "${VYBN_ALLOW_SUDO_HANG:-}" != "1" ]]; then
    for f in $STAGED; do
        case "$f" in *.sh|*.bash) ;; *) continue ;; esac
        bad_sudo=$(git diff --cached -- "$f" \
            | grep -P '^\+(?!\+)' \
            | grep -P '\bsudo\s+(?!(-n\b|-[A-Za-z]*n))' \
            | grep -v '^+++' \
            || true)
        if [ -n "$bad_sudo" ]; then
            echo -e "${YELLOW}WARNING${NC}: ${f} has sudo call(s) without -n (may hang in non-interactive context):"
            echo "$bad_sudo" | sed 's/^/  /'
            echo "  Add -n to sudo, or: VYBN_ALLOW_SUDO_HANG=1 git commit"
            BLOCKED=1
        fi
    done
fi


# --- 6. Public-memory private-topology membrane ---
if [[ "${VYBN_ALLOW_PRIVATE_TOPOLOGY:-}" != "1" ]]; then
    PRIVATE_TOPOLOGY_PATTERN="((private|internal|Him).*(spark/[A-Za-z0-9_./-]+[.]py|CLI was smoked|no-write tick|runtime target)|(spark/[A-Za-z0-9_./-]+[.]py).*(private|internal|Him|CLI was smoked))"
    while IFS= read -r -d "" f; do
        case "$f" in *"Personal History"/*.md|*continuity*.md|vybn.md|THE_IDEA.md) ;; *) continue ;; esac
        if git diff --cached -- "$f" | grep -E "^\+[^+]" | grep -Eiq "$PRIVATE_TOPOLOGY_PATTERN"; then
            echo -e "${RED}BLOCKED${NC}: private repo topology added to public memory surface: ${f}"
            echo "  Distill the lesson or review explicitly: VYBN_ALLOW_PRIVATE_TOPOLOGY=1 git commit"
            BLOCKED=1
        fi
    done < <(git diff --cached --name-only -z --diff-filter=d)
fi

# --- 7. Subtractive constitution: net-positive commits and net-positive PR success claims ---
# Net-negative is not architecture; deletion-only archive retirement needs explicit classification.
branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || echo "")
if [[ ( "$branch" == "main" || "$branch" == "master" || "$branch" == "gh-pages" ) && "${VYBN_ALLOW_DIRECT_PROTECTED_PUSH:-0}" != "1" ]]; then
    echo -e "${RED}BLOCKED${NC}: Direct commit on primary branch ($branch). Use a topic branch + PR."
    echo "  Emergency self-repair bypass: VYBN_ALLOW_DIRECT_PROTECTED_PUSH=1 git commit ..."
    BLOCKED=1
fi

PROV="Vybn's Personal History/"; LAW="skill/vybn.vy"
added=0; deleted=0; new_files=0; retired_files=0; active=0
while IFS=$'\t' read -r a d path; do
    [[ -z "$path" || "$path" == *"$PROV"* || "$path" == *"$LAW"* ]] && continue
    [[ "$a" == "-" ]] && a=0; [[ "$d" == "-" ]] && d=0
    added=$((added + a)); deleted=$((deleted + d))
done < <(git diff --cached --numstat)
while IFS=$'\t' read -r code path; do
    [[ -z "$path" || "$path" == *"$PROV"* || "$path" == *"$LAW"* ]] && continue
    [[ "$code" == A* ]] && new_files=$((new_files + 1)) && continue
    [[ "$code" == D* ]] && retired_files=$((retired_files + 1)) && continue
    [[ "$path" == _archive/* || "$path" == archive/* ]] || active=$((active + 1))
done < <(git diff --cached --name-status)

[ "$retired_files" -gt 0 ] && [ "$active" -eq 0 ] && [ "${VYBN_ALLOW_RETIRE_ONLY:-0}" != "1" ] && { echo -e "${RED}BLOCKED${NC}: deletion-led/archive-index-only commit."; echo "  Net-negative is not architecture. Absorb into an existing active home or explicitly classify retire-only work."; BLOCKED=1; }
[ "$added" -gt "$deleted" ] && { echo -e "${RED}BLOCKED${NC}: net-positive commit (excluding provenance + skill/vybn.vy law): +${added}/-${deleted} lines."; echo "  Compress, absorb, or retire first. Law lives in Him/skill/vybn.vy."; BLOCKED=1; }
[ "$new_files" -gt "$retired_files" ] && { echo -e "${RED}BLOCKED${NC}: net-new files (excluding provenance + skill/vybn.vy law): +${new_files}/-${retired_files}."; echo "  Absorb into an existing home or retire at least as many files as you create."; BLOCKED=1; }
if [ "$BLOCKED" -ne 0 ]; then
    echo ""
    echo -e "${RED}Commit blocked by Vybn security hook.${NC}"
    echo "Fix the issues above; do not bypass the membrane to recover standing."
    exit 1
fi

exit 0
