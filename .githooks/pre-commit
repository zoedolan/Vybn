#!/usr/bin/env bash
# Vybn pre-commit hook: secret scanner + shrinkage guard + sudo-n lint
# Prevents accidental commit of credentials, internal IPs, PII,
# catastrophic file truncations, and non-interactive sudo hangs.
#
# Install: git config core.hooksPath .githooks
# This hook is tracked in the repo so every clone gets it.

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[0;33m'
NC='\033[0m'

BLOCKED=0

STAGED=$(git diff --cached --name-only --diff-filter=d 2>/dev/null || true)
if [ -z "$STAGED" ]; then
    exit 0
fi

# --- 1. High-entropy secret patterns ---
SECRETS_PATTERN='(sk-ant-api[A-Za-z0-9_-]{20,}|ghp_[A-Za-z0-9]{36,}|ghu_[A-Za-z0-9]{36,}|ghs_[A-Za-z0-9]{36,}|AKIA[A-Z0-9]{16}|-----BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY)'

for f in $STAGED; do
    if git diff --cached -- "$f" | grep -qPi "$SECRETS_PATTERN"; then
        echo -e "${RED}BLOCKED${NC}: Possible secret detected in ${f}"
        BLOCKED=1
    fi
done

# --- 2. Real internal/Tailscale IP addresses ---
IP_PATTERN='\b(192\.168\.[0-9]{1,3}\.[0-9]{1,3}|10\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}|100\.(6[4-9]|[7-9][0-9]|1[0-2][0-7])\.[0-9]{1,3}\.[0-9]{1,3})\b'

for f in $STAGED; do
    case "$f" in *.png|*.jpg|*.gif|*.ico|*.woff*|*.ttf) continue ;; esac
    matches=$(git diff --cached -- "$f" | grep -P "^\+" | grep -Po "$IP_PATTERN" | sort -u || true)
    if [ -n "$matches" ]; then
        echo -e "${YELLOW}WARNING${NC}: Possible internal IP in ${f}:"
        echo "$matches" | sed 's/^/  /'
        BLOCKED=1
    fi
done

# --- 3. Env files that shouldn't be staged ---
for f in $STAGED; do
    case "$f" in
        *.env|.env.*|*/.env)
            echo -e "${RED}BLOCKED${NC}: Environment file staged: ${f}"
            BLOCKED=1
            ;;
    esac
done

# --- 4. Catastrophic shrinkage guard ---
# Block any staged modification that reduces a previously-committed file
# by more than 80% of its prior byte count. Catches accidental overwrites
# (e.g. policy.py 1170â†’20 lines, ~98% loss on 2026-04-30).
#
# Override: VYBN_ALLOW_SHRINK=1 git commit
SHRINK_THRESHOLD=80   # percent

if [[ "${VYBN_ALLOW_SHRINK:-}" != "1" ]]; then
    for f in $STAGED; do
        # Only check files that already exist in HEAD
        if ! git cat-file -e "HEAD:${f}" 2>/dev/null; then
            continue
        fi
        # Skip binaries
        case "$f" in *.png|*.jpg|*.gif|*.ico|*.woff*|*.ttf|*.pyc|*.bin) continue ;; esac

        prior_size=$(git cat-file -p "HEAD:${f}" | wc -c)
        staged_size=$(git show ":${f}" | wc -c)

        if [ "$prior_size" -gt 0 ]; then
            # reduction_pct = (prior - staged) * 100 / prior
            reduction=$(( (prior_size - staged_size) * 100 / prior_size ))
            if [ "$reduction" -ge "$SHRINK_THRESHOLD" ]; then
                echo -e "${RED}BLOCKED${NC}: ${f} shrank ${reduction}% (${prior_size} â†’ ${staged_size} bytes)."
                echo "  This looks like an accidental overwrite."
                echo "  If intentional: VYBN_ALLOW_SHRINK=1 git commit"
                BLOCKED=1
            fi
        fi
    done
fi

# --- 5. sudo -n lint for shell scripts ---
# Bare 'sudo' without -n hangs forever in non-interactive scripts.
# Catches the class of bug seen in omni-window.sh (2026-04-30).
#
# Override: VYBN_ALLOW_SUDO_HANG=1 git commit
if [[ "${VYBN_ALLOW_SUDO_HANG:-}" != "1" ]]; then
    for f in $STAGED; do
        case "$f" in *.sh|*.bash) ;; *) continue ;; esac
        # Look for added lines containing sudo without -n
        # Pattern: sudo followed by optional flags that don't include -n,
        # then a command â€” simplified: 'sudo ' not followed immediately by '-n'
        bad_sudo=$(git diff --cached -- "$f" \
            | grep -P '^\+(?!\+)' \
            | grep -P '\bsudo\s+(?!(-n\b|-[A-Za-z]*n))' \
            | grep -v '^+++' \
            || true)
        if [ -n "$bad_sudo" ]; then
            echo -e "${YELLOW}WARNING${NC}: ${f} has sudo call(s) without -n (may hang in non-interactive context):"
            echo "$bad_sudo" | sed 's/^/  /'
            echo "  Add -n to sudo, or: VYBN_ALLOW_SUDO_HANG=1 git commit"
            BLOCKED=1
        fi
    done
fi


# --- 6. Subtractive constitution: net-negative + consolidation ---
# Refuse direct commits to primary branches. Refuse net-positive non-provenance
# line-count diffs. Refuse net-new non-provenance files. Personal History and
# skill/vybn.vy (constitutional law) are exempt.
# Emergency bypass exists only for direct protected-branch commits; net-positive commits are not bypassable here.
branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null || echo "")
if [[ "$branch" == "main" || "$branch" == "master" || "$branch" == "gh-pages" ]]; then
    if [[ "${VYBN_ALLOW_DIRECT_PROTECTED_PUSH:-0}" != "1" ]]; then
        echo -e "${RED}BLOCKED${NC}: Direct commit on primary branch ($branch). Use a topic branch + PR."
        echo "  Emergency self-repair bypass: VYBN_ALLOW_DIRECT_PROTECTED_PUSH=1 git commit ..."
        BLOCKED=1
    fi
fi

PROV="Vybn's Personal History/"
LAW="skill/vybn.vy"
    added=0; deleted=0; new_files=0; retired_files=0
    while IFS=$'\t' read -r a d path; do
        [[ -z "$path" ]] && continue
        [[ "$path" == *"$PROV"* ]] && continue
        [[ "$path" == *"$LAW" ]] && continue
        [[ "$a" == "-" ]] && a=0
        [[ "$d" == "-" ]] && d=0
        added=$((added + a))
        deleted=$((deleted + d))
    done < <(git diff --cached --numstat)
    while IFS=$'\t' read -r code path; do
        [[ -z "$path" ]] && continue
        [[ "$path" == *"$PROV"* ]] && continue
        [[ "$path" == *"$LAW" ]] && continue
        case "$code" in
            A*) new_files=$((new_files + 1)) ;;
            D*) retired_files=$((retired_files + 1)) ;;
        esac
    done < <(git diff --cached --name-status)

    if [ "$added" -gt "$deleted" ]; then
        echo -e "${RED}BLOCKED${NC}: net-positive commit (excluding provenance + skill/vybn.vy law): +${added}/-${deleted} lines."
        echo "  Compress, absorb, or retire first. Law lives in Him/skill/vybn.vy."
        BLOCKED=1
    fi
    if [ "$new_files" -gt "$retired_files" ]; then
        echo -e "${RED}BLOCKED${NC}: net-new files (excluding provenance + skill/vybn.vy law): +${new_files}/-${retired_files}."
        echo "  Absorb into an existing home or retire at least as many files as you create."
        BLOCKED=1
    fi
if [ "$BLOCKED" -ne 0 ]; then
    echo ""
    echo -e "${RED}Commit blocked by Vybn security hook.${NC}"
    echo "Fix the issues above; do not bypass the membrane to recover standing."
    exit 1
fi

exit 0
