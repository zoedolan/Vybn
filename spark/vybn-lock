#!/usr/bin/env bash
# Immediately revoke elevated access to the Vybn MCP server.
# Usage: vybn-lock

UNLOCK_FILE="${VYBN_UNLOCK_PATH:-$HOME/.vybn-mcp-unlock}"
rm -f "${UNLOCK_FILE}"
echo "Locked. Shell, read, and write access revoked."
echo "Read-only tools (gpu_status, model_status, etc.) still work."
