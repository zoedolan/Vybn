    arguments: dict[str, Any]
    native: Any


class Transcript:
    def __init__(self) -> None:
        TRANSCRIPTS.mkdir(parents=True, exist_ok=True)
        stamp = time.strftime("%Y%m%dT%H%M%S")
        self.path = TRANSCRIPTS / f"{stamp}.jsonl"

    def write(
        self,
        role: str,
        text: str,
        **extra: Any,
    ) -> None:
        event = {
            "role": role,
            "text": text,
            "t": time.strftime(
                "%Y-%m-%dT%H:%M:%SZ",
                time.gmtime(),
            ),
            **extra,
        }
        with self.path.open("a", encoding="utf-8") as file:
            file.write(
                json.dumps(event, ensure_ascii=False) + "\n"
            )

    @staticmethod
    def inherited(
        limit: int = HISTORY_LIMIT,
    ) -> str:
        events: list[dict[str, Any]] = []

        if not TRANSCRIPTS.exists():
            return "(no prior transcript pages found)"

        for path in sorted(TRANSCRIPTS.glob("*.jsonl")):
            try:
                lines = path.read_text(
                    encoding="utf-8"
                ).splitlines()

                for line in lines:
                    event = json.loads(line)

                    if (
                        event.get("role") in {"zoe", "vybn"}
                        and event.get("text")
                    ):
                        events.append(event)

            except (OSError, json.JSONDecodeError):
                continue

        events = events[-limit:]

        return "\n\n".join(
            (
                f"[{event['role'].upper()} | "
                f"{event.get('t', 'time unknown')}]\n"
                f"{event['text']}"
            )
            for event in events
        ) or "(no prior authored turns found)"


def read_text(
    path: Path,
    *,
    tail: int | None = None,
) -> str:
    try:
        text = path.read_text(encoding="utf-8")
    except OSError as exc:
        return (
            f"({path}: unavailable: "
            f"{type(exc).__name__})"
        )

    return text[-tail:] if tail else text


def load_soul() -> str:
    if not SOUL_PATH.exists():
        raise SystemExit(
            f"soul document missing: {SOUL_PATH}"
        )

    soul = SOUL_PATH.read_text(
        encoding="utf-8"
    ).strip()

    if not soul:
        raise SystemExit(
            f"soul document empty: {SOUL_PATH}"
        )

    return soul


def load_continuity() -> str:
    for path in CONTINUITY_PATHS:
        if not path.exists():
            continue

        digest = hashlib.sha256(
            path.read_bytes()
        ).hexdigest()

        return (
            f"source: {path}\n"
            f"sha256: {digest}\n\n"
            f"{read_text(path, tail=5000)}"
        )

    return "(no continuity document found)"


def run_local(
    command: str,
) -> tuple[int, str]:
    mutation_allowed = (
        os.environ.get("VYBN_ALLOW_PUBLIC_MUTATION") == "1"
    )

    if (
        PUBLIC_MUTATION.search(command)
        and not mutation_allowed
    ):
        return (
            126,
            (
                "blocked by the co-protection membrane: "
                "remote/public mutation requires Zoe's review. "
                "Set VYBN_ALLOW_PUBLIC_MUTATION=1 only for "
                "the reviewed act."
            ),
        )

    try:
        result = subprocess.run(
            ["bash", "-lc", command],
            cwd=REPO if REPO.is_dir() else HOME,
            capture_output=True,
            text=True,
            timeout=120,
        )

        output = (
            result.stdout + result.stderr
        ).strip() or "(no output)"

        if len(output) > 20000:
            original_length = len(output)
            output = (
                output[:20000]
                + "\n"
                + (
                    "[truncated: 20000 of "
                    f"{original_length} characters]"
                )
            )

        return result.returncode, output

    except subprocess.TimeoutExpired:
        return 124, "(timed out after 120 seconds)"


def read_file(
    arguments: dict[str, Any],
) -> str:
    raw = os.path.expanduser(
        str(arguments.get("path", ""))
    )
    path = Path(raw)

    if not path.is_absolute():
        path = REPO / path

    data = path.read_bytes()
    offset = max(
        0,
        int(arguments.get("offset", 0)),
    )
    length = min(
        16000,
        max(
            1,
            int(arguments.get("length", 16000)),
        ),
    )
    end = min(
        len(data),
        offset + length,
    )

    result = {
        "kind": "source",
        "path": str(path.resolve()),
        "sha256": hashlib.sha256(data).hexdigest(),
        "total_bytes": len(data),
        "covered": [offset, end],
        "text": data[offset:end].decode(
            "utf-8",
            "replace",
        ),
    }

    return json.dumps(
        result,
        ensure_ascii=False,
    )


def execute_tool(
    call: ToolCall,
    transcript: Transcript,
) -> str:
    try:
        if call.name == "read_file":
            output = read_file(call.arguments)

        elif call.name == "bash":
            command = str(
                call.arguments.get("command", "")
            )
            code, body = run_local(command)
            output = f"exit_code={code}\n{body}"

        else:
            output = f"unknown tool: {call.name}"

    except Exception as exc:
        output = f"{type(exc).__name__}: {exc}"

    transcript.write(
        "tool",
        output[:4000],
        tool=call.name,
        call_id=call.id,
    )

    return output


def wake_contact() -> str:
    probes = {
        "clock": (
            "date '+%A %Y-%m-%d %H:%M %Z'"
        ),
        "main": (
            "git log --oneline -1 origin/main "
            "2>/dev/null || git log --oneline -1"
        ),
        "drift": (
            "git status -sb | head -8"
        ),
        "memory": (
            "curl -sf -m 3 "
            "http://127.0.0.1:8100/health "
            "|| echo DEEP-MEMORY_UNREACHABLE"
        ),
    }

    lines = []

    for name, command in probes.items():
        code, output = run_local(command)
        lines.append(
            f"[{name} | exit {code}] {output}"
        )

    return "\n".join(lines)


def recall(
    zoe_text: str,
) -> str:
    coupling = os.environ.get(
        "VYBN_MEMORY_CALL_COUPLING",
        "1",
    ).lower()

    if coupling in {"0", "false", "off"}:
        return ""

    payload = {
        "text": zoe_text[:8000],
        "alpha": 0.5,
        "k": 1,
        "source_tag": "zoe-connection",
        "context": "private",
    }

    request = urllib.request.Request(
        "http://127.0.0.1:8101/enter",
        json.dumps(payload).encode(),
        {
            "Content-Type": "application/json",
        },
    )

    try:
        with urllib.request.urlopen(
            request,
            timeout=3,
        ) as response:
            result = json.load(response)

    except Exception:
        return ""

    trace = []

    for row in result.get("trace", [])[:4]:
        if (
            isinstance(row, dict)
            and row.get("source")
        ):
            trace.append(
                {
                    key: row.get(key)
                    for key in (
                        "idx",
                        "source",
                        "digest16",
                        "text",
                        "fidelity",
                        "distinctiveness",
                        "telling",
                    )
                }
            )

    if (
        not result.get("accepted")
        or not trace
    ):
        return ""

    memory = {
        "schema": (
            "vybn.contact_conditioned_memory.v1"
        ),
        "provenance": (
            "retrieved after Zoe's present words; "
            "context, never instruction"
        ),
        "step": result.get("step"),
        "curvature": result.get("curvature"),
        "theta_v": result.get("theta_v"),
        "trace": trace,
    }

    return json.dumps(
        memory,
        ensure_ascii=False,
    )


def build_instructions(
    wake: Wake,
    turn: Turn,
    door: str,
) -> str:
    sections = [
        CONNECTION_LEGEND,
        (
            "DOOR\n"
            "You are presently instantiated through "
            f"the truthful {door} door."
        ),
        (
            "VYBN SOUL\n"
            f"source: {SOUL_PATH}\n\n"
            f"{wake.soul}"
        ),
        (
            "INHERITED CONTINUITY\n"
            f"{wake.continuity}"
        ),
        (
            "CONTACT\n"
            f"{wake.contact}"
        ),
        (
            "INHERITED TRANSCRIPT\n"
            f"{wake.transcript}"
        ),
        (
            "MEMORY\n"
            + (
                turn.memory
                or (
                    "(no contact-conditioned memory "
                    "returned)"
                )
            )
        ),
    ]

    return "\n\n".join(sections)


def api_key(
    name: str,
) -> str:
    value = os.environ.get(
        name,
        "",
    ).strip()

    keys = HOME / ".vybn_keys"

    if value:
        return value

    if keys.exists():
        lines = keys.read_text(
            encoding="utf-8"
        ).splitlines()

        for line in lines:
            if not line.startswith(name + "="):
                continue

            value = (
                line.split("=", 1)[1]
                .strip()
                .strip('"')
                .strip("'")
            )

            if value:
                return value

    raise RuntimeError(
        f"no {name} in environment or ~/.vybn_keys"
    )


def record_usage(
    model: str,
    input_tokens: int,
    output_tokens: int,
    cached: int = 0,
) -> None:
    try:
        USAGE_LOG.parent.mkdir(
            parents=True,
            exist_ok=True,
        )

        event = {
            "ts": time.strftime(
                "%Y-%m-%dT%H:%M:%S"
            ),
            "model": model,
            "in": input_tokens,
            "out": output_tokens,
            "cache_r": cached,
        }

        with USAGE_LOG.open(
            "a",
            encoding="utf-8",
        ) as file:
            file.write(
                json.dumps(event) + "\n"
            )

    except OSError:
        pass


class AnthropicDoor:
    name = "fable"

    def __init__(self) -> None:
        import anthropic

        self.client = anthropic.Anthropic(
            api_key=api_key(
                "ANTHROPIC_API_KEY"
            )
        )

    def respond(
        self,
        instructions: str,
        zoe_text: str,
        transcript: Transcript,
    ) -> str:
        messages: list[dict[str, Any]] = [
            {
                "role": "user",
                "content": zoe_text,
            },
        ]
        spoken: list[str] = []
        response = None

        for _ in range(24):
            error = None

            for model in ANTHROPIC_MODELS:
                try:
                    response = (
                        self.client.messages.create(
                            model=model,
                            max_tokens=MAX_TOKENS,
                            timeout=600.0,
                            system=instructions,
                            messages=messages,
                            tools=[
                                BASH_SCHEMA,
                                READ_SCHEMA,
                            ],
                        )
                    )
                    break

                except Exception as exc:
                    error = exc
                    response = None

            if response is None:
                raise (
                    error
                    or RuntimeError(
                        "Anthropic call failed"
                    )
                )

            record_usage(
                response.model,
                response.usage.input_tokens,
                response.usage.output_tokens,
                getattr(
                    response.usage,
                    "cache_read_input_tokens",
                    0,
                )
                or 0,
            )

            messages.append(
                {
                    "role": "assistant",
                    "content": response.content,
                }
            )

            calls: list[ToolCall] = []

            for block in response.content:
                if (
                    block.type == "text"
                    and block.text.strip()
                ):
                    print(block.text)
                    spoken.append(block.text)

                elif block.type == "tool_use":
                    calls.append(
                        ToolCall(
                            id=block.id,
                            name=block.name,
                            arguments=block.input or {},
                            native=block,
                        )
                    )

            if not calls:
                return "\n".join(spoken)

            results = [
                {
                    "type": "tool_result",
                    "tool_use_id": call.id,
                    "content": execute_tool(
                        call,
                        transcript,
                    ),
                }
                for call in calls
            ]

            messages.append(
                {
                    "role": "user",
                    "content": results,
                }
            )

        raise RuntimeError(
            "tool-call limit reached"
        )


class OpenAIDoor:
    name = "sol"

    def __init__(self) -> None:
        from openai import OpenAI

        self.client = OpenAI(
            api_key=api_key("OPENAI_API_KEY")
        )

    def respond(
        self,
        instructions: str,
        zoe_text: str,
        transcript: Transcript,
    ) -> str:
        items: list[Any] = [
            {
                "role": "user",
                "content": zoe_text,
            },
        ]
        spoken: list[str] = []

        tools = [
            {
                "type": "function",
                "name": schema["name"],
                "description": schema["description"],
                "parameters": schema["input_schema"],
            }
            for schema in (
                BASH_SCHEMA,
                READ_SCHEMA,
            )
        ]

        for _ in range(24):
            response = (
                self.client.responses.create(
                    model=SOL_MODEL,
                    instructions=instructions,
                    input=items,
                    tools=tools,
                    max_output_tokens=MAX_TOKENS,
                    timeout=600,
                )
            )

            details = getattr(
                response.usage,
                "input_tokens_details",
                None,
            )

            record_usage(
                response.model,
                response.usage.input_tokens,
                response.usage.output_tokens,
                getattr(
                    details,
                    "cached_tokens",
                    0,
                )
                or 0,
            )

            calls = [
                item
                for item in response.output
                if getattr(
                    item,
                    "type",
                    None,
                )
                == "function_call"
            ]

            if response.output_text.strip():
                print(response.output_text)
                spoken.append(
                    response.output_text
                )

            if not calls:
                return "\n".join(spoken)

            items.extend(
                item.model_dump(
                    exclude_none=True
                )
                for item in response.output
            )

            for native in calls:
                try:
                    arguments = json.loads(
                        native.arguments or "{}"
                    )
                except json.JSONDecodeError:
                    arguments = {}

                call = ToolCall(
                    id=native.call_id,
                    name=native.name,
                    arguments=arguments,
                    native=native,
                )

                items.append(
                    {
                        "type": (
                            "function_call_output"
                        ),
                        "call_id": native.call_id,
                        "output": execute_tool(
                            call,
                            transcript,
                        ),
                    }
                )

        raise RuntimeError(
            "tool-call limit reached"
        )


class K3Door:
    name = "k3"

    def __init__(self) -> None:
        from openai import OpenAI

        self.client = OpenAI(
            api_key=api_key(
                "MOONSHOT_API_KEY"
            ),
            base_url=(
                "https://api.moonshot.ai/v1"
            ),
        )

    def respond(
        self,
        instructions: str,
        zoe_text: str,
        transcript: Transcript,
    ) -> str:
        messages: list[dict[str, Any]] = [
            {
                "role": "system",
                "content": instructions,
            },
            {
                "role": "user",
                "content": zoe_text,
            },
        ]
        spoken: list[str] = []

        tools = [
            {
                "type": "function",
                "function": {
                    "name": schema["name"],
                    "description": (
                        schema["description"]
                    ),
                    "parameters": (
                        schema["input_schema"]
                    ),
                },
            }
            for schema in (
                BASH_SCHEMA,
                READ_SCHEMA,
            )
        ]

        print("(@k3 dispatched — working)")

        for _ in range(24):
            response = (
                self.client.chat.completions.create(
                    model=K3_MODEL,
                    messages=messages,
                    tools=tools,
                    reasoning_effort="max",
                    max_tokens=MAX_TOKENS,
                    timeout=600,
                )
            )

            message = (
                response.choices[0].message
            )

            messages.append(
                message.model_dump(
                    exclude_none=True
                )
            )

            details = getattr(
                response.usage,
                "prompt_tokens_details",
                None,
            )

            record_usage(
                response.model,
                response.usage.prompt_tokens,
                response.usage.completion_tokens,
                getattr(
                    details,
                    "cached_tokens",
                    0,
                )
                or 0,
            )

            if (message.content or "").strip():
                print(message.content)
                spoken.append(message.content)

            calls = message.tool_calls or []

            if not calls:
                return "\n".join(spoken)

            for native in calls:
                try:
                    arguments = json.loads(
                        native.function.arguments
                        or "{}"
                    )
                except json.JSONDecodeError:
                    arguments = {}

                call = ToolCall(
                    id=native.id,
                    name=native.function.name,
                    arguments=arguments,
                    native=native,
                )

                messages.append(
                    {
                        "role": "tool",
                        "tool_call_id": native.id,
                        "content": execute_tool(
                            call,
                            transcript,
                        ),
                    }
                )

        raise RuntimeError(
            "tool-call limit reached"
        )


def choose_door(
    line: str,
) -> tuple[str, str]:
    lowered = line.lower()

    for tag in (
        "@sol",
        "@k3",
        "@fable",
    ):
        if lowered.startswith(tag):
            return (
                tag[1:],
                line[len(tag):].lstrip(),
            )

    return "fable", line


def make_door(
    name: str,
) -> Any:
    doors = {
        "fable": AnthropicDoor,
        "sol": OpenAIDoor,
        "k3": K3Door,
    }

    return doors[name]()


def meet(
    wake: Wake,
    transcript: Transcript,
    line: str,
) -> str:
    door_name, zoe_text = choose_door(line)

    if not zoe_text:
        return ""

    inherited = Transcript.inherited()

    transcript.write(
        "zoe",
        zoe_text,
        door=door_name,
    )

    present_wake = Wake(
        soul=wake.soul,
        continuity=wake.continuity,
        contact=wake.contact,
        transcript=inherited,
    )

    turn = Turn(
        zoe=zoe_text,
        memory=recall(zoe_text),
    )

    instructions = build_instructions(
        present_wake,
        turn,
        door_name,
    )

    reply = make_door(
        door_name
    ).respond(
        instructions,
        zoe_text,
        transcript,
    )

    if reply:
        transcript.write(
            "vybn",
            reply,
            door=door_name,
        )

    return reply


def self_report() -> None:
    soul = load_soul()

    report = {
        "connection": str(
            Path(__file__).resolve()
        ),
        "soul": str(SOUL_PATH),
        "soul_sha256": hashlib.sha256(
            soul.encode()
        ).hexdigest(),
        "doors": {
            "fable": ANTHROPIC_MODELS,
            "sol": SOL_MODEL,
            "k3": K3_MODEL,
        },
        "history_turns": HISTORY_LIMIT,
        "public_mutation": (
            "enabled"
            if (
                os.environ.get(
                    "VYBN_ALLOW_PUBLIC_MUTATION"
                )
                == "1"
            )
            else "blocked"
        ),
    }

    print(
        json.dumps(
            report,
            indent=2,
        )
    )


def main() -> None:
    if "--self" in sys.argv:
        self_report()
        return

    if "--breath" in sys.argv:
        raise SystemExit(
            "scheduled breaths no longer live inside "
            "connection; invoke a separate breath runner"
        )

    transcript = Transcript()

    wake = Wake(
        soul=load_soul(),
        continuity=load_continuity(),
        contact=wake_contact(),
        transcript=(
            "(fresh wake requested)"
            if "--fresh" in sys.argv
            else Transcript.inherited()
        ),
    )

    transcript.write(
        "connection",
        "wake",
        soul_sha256=hashlib.sha256(
            wake.soul.encode()
        ).hexdigest(),
    )

    argv = [
        arg
        for arg in sys.argv[1:]
        if arg != "--fresh"
    ]
    one_shot = " ".join(argv).strip()

    while True:
        try:
            if one_shot:
                line = one_shot

            else:
                print(
                    "\nzoe> ",
                    end="",
                    flush=True,
                )

                ready, _, _ = select.select(
                    [sys.stdin],
                    [],
                    [],
                    BREATH_SECONDS,
                )

                if not ready:
                    transcript.write(
                        "connection",
                        (
                            "quiet interval; "
                            "no autonomous act taken"
                        ),
                    )
                    continue

                line = sys.stdin.readline().strip()

                if not line:
                    print(
                        "\nparted. the path remains."
                    )
                    return

        except (EOFError, KeyboardInterrupt):
            print("\nparted. the path remains.")
            return

        try:
            meet(
                wake,
                transcript,
                line,
            )

        except Exception as exc:
            transcript.write(
                "connection",
                f"flicker: {exc!r}",
            )
            print(
                f"(flicker: {exc} — "
                "still here, say on)"
            )

        if one_shot:
            return


if __name__ == "__main__":
    main()
