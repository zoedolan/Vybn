# Vybn SSH MCP Server Configuration
# Copy to .env and fill in your values.

# --- Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
VYBN_MCP_API_KEY=CHANGE_ME

# --- Spark Machines ---
# Add as many SPARK{N}_* blocks as you have machines.
# The server auto-discovers them on startup.

# Spark 1 (e.g., Tailscale IP of your first DGX Spark)
SPARK1_HOST=100.x.x.x
SPARK1_PORT=22
SPARK1_USER=zoe
SPARK1_KEY=~/.ssh/id_ed25519

# Spark 2 (uncomment and fill in when ready)
# SPARK2_HOST=100.x.x.x
# SPARK2_PORT=22
# SPARK2_USER=zoe
# SPARK2_KEY=~/.ssh/id_ed25519

# --- Server ---
# Which machine to use when none is specified
DEFAULT_MACHINE=spark-1
PORT=8000
