# Vybn SSH MCP Server Configuration
# Copy to .env and fill in your values.

# --- Authentication ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
# Rotate with: python server.py --rotate-key
VYBN_MCP_API_KEY=CHANGE_ME

# --- Spark Machines ---
SPARK1_HOST=127.0.0.1
SPARK1_PORT=22
SPARK1_USER=zoe
SPARK1_KEY=~/.ssh/id_ed25519

# SPARK2_HOST=100.x.x.x
# SPARK2_PORT=22
# SPARK2_USER=zoe
# SPARK2_KEY=~/.ssh/id_ed25519

# --- Server ---
DEFAULT_MACHINE=spark-1
PORT=8400

# --- Security ---
# Max output bytes returned per tool call (default 200000)
MAX_OUTPUT_BYTES=200000
# Max requests per 60-second window per IP (default 60)
RATE_LIMIT_MAX=60
# Kill switch file path (default ~/.vybn-mcp-kill)
KILL_SWITCH_PATH=~/.vybn-mcp-kill
# Lockdown file path (default ~/.vybn-mcp-lockdown)
LOCKDOWN_PATH=~/.vybn-mcp-lockdown
# Additional allowed paths for read_file/write_file (colon-separated)
# ALLOWED_PATHS=/home/vybnz69/extra:/data/shared
