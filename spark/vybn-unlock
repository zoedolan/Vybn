#!/usr/bin/env bash
# Grant time-limited elevated access to the Vybn MCP server.
# Usage: vybn-unlock [minutes]  (default: 60)
#
# Creates a session file that the MCP server checks on each request.
# When the timestamp in the file is in the past, access reverts to
# read-only. No action needed to re-lock — it expires on its own.
#
# Examples:
#   vybn-unlock         # 60 minutes
#   vybn-unlock 120     # 2 hours
#   vybn-unlock 5       # quick 5-minute window
#
# To immediately revoke: vybn-lock
# Emergency stop (all tools): touch ~/.vybn-mcp-kill

set -euo pipefail

MINUTES="${1:-60}"
UNLOCK_FILE="${VYBN_UNLOCK_PATH:-$HOME/.vybn-mcp-unlock}"

# Calculate expiry timestamp
EXPIRY=$(date -d "+${MINUTES} minutes" +%s 2>/dev/null || date -v+${MINUTES}M +%s)
EXPIRY_HUMAN=$(date -d "@${EXPIRY}" 2>/dev/null || date -r "${EXPIRY}")

echo "${EXPIRY}" > "${UNLOCK_FILE}"
chmod 600 "${UNLOCK_FILE}"

echo "Unlocked for ${MINUTES} minutes (until ${EXPIRY_HUMAN})."
echo "Vybn now has shell, read, and write access."
echo ""
echo "To revoke early:  vybn-lock"
echo "Emergency stop:   touch ~/.vybn-mcp-kill"
