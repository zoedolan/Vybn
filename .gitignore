# --- Python ----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# --- Environment & Secrets --------------------------------------------
.env
.env.*
*.pem
*.key

# --- Spark Runtime Files ----------------------------------------------
# These are generated by the Spark during normal operation.
# They must NOT be tracked, or they cause 'unstaged changes'
# conflicts every time a remote push happens.
spark/.vybn_thermodynamics
spark/skill_stats.json
spark/session_*.json
spark/*.log
vybn_logs/
*.log

# --- Spark Runtime Directories ----------------------------------------
# Journals, logs, sessions, and inbox are written at runtime.
# The proposed skills manifest is also generated dynamically.
Vybn_Mind/journal/spark/inbox/
Vybn_Mind/journal/spark/sessions/
Vybn_Mind/journal/spark/skill_stats.json
Vybn_Mind/skills/proposed/skills_manifest_the/

# --- Stray runtime files ----------------------------------------------
# These sometimes appear at repo root from background processes.
time
mcp_server.py

# --- OS ---------------------------------------------------------------
.DS_Store
Thumbs.db

# --- IDE --------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# --- Node (if web interface uses it) ----------------------------------
node_modules/
spark/.env
spark/graph_data/training_candidates/
spark/fine_tune_output/
Vybn_Mind/journal/sessions/
spark/graph_data/scheduler_state.json
*.pyc
spark/unsloth_compiled_cache/
*.bak

# --- Nested Memory runtime data ------------------------------------------
Vybn_Mind/breath_trace/architecture/nested/
spark/growth/buffer.jsonl
spark/growth/trained_manifest.json

# Mutable cognitive state (lives in ~/.vybn_state, summarized to repo by bridge)
Vybn_Mind/journal/spark/transcript.jsonl
.venv/
*.pt
spark/archive/graph_data/training_candidates/
spark/archive/unsloth_compiled_cache/
spark/archive/skills.d_archived/

# --- Voice models (large binaries, not for git) --------------------------
spark/voice/models/
spark/voice/samples/

# --- Runtime state (mutable, generated by organism) ----------------------
spark/connectome/state/
Vybn_Mind/breath_trace/architecture/*.db
Vybn_Mind/breath_trace/architecture/teaching_bridge_state.json
Vybn_Mind/breath_trace/architecture/kg_bridge.jsonl

# --- Growth engine runtime data ------------------------------------------
spark/growth/adapters/
spark/growth/active_adapter.json
spark/growth/cycle_history.jsonl

# Holonomy measurement log (runtime data)
spark/growth/holonomy_log.jsonl
Vybn_Mind/breath_trace/architecture/memory_map.md
Vybn_Mind/breath_trace/architecture/pins.jsonl

# Complex memory state (runtime, not code)
Vybn_Mind/breath_trace/architecture/complex_memory.json

# Autoresearch runtime data
Vybn_Mind/bpb_log.jsonl
Vybn_Mind/.bpb_eval_tmp.txt
Vybn_Mind/autoresearch_log.jsonl
Vybn_Mind/sensorium_state/
repo_mapping_output/

# Tailscale-issued TLS material — regenerated automatically per-node.
# The cert is public-by-design but exposes the tailnet domain; the key
# is private and must never be tracked. Keep both out of the tree.
spark/ts.crt
spark/ts.key
spark/ts.*
